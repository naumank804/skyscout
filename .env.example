# ──────────────────────────────────────────────────
# SkyScout Environment Variables
# ──────────────────────────────────────────────────
# Copy this file to .env.local

# Travelpayouts White Label ID
# Get this from: Travelpayouts Dashboard → Tools → White Label Web → Create
# After creating, you'll see your WL ID in the URL or settings
NEXT_PUBLIC_WL_ID=your_wl_id_here

# Travelpayouts API token (for data API - deals page, etc.)
TRAVELPAYOUTS_TOKEN=your_token_here
TRAVELPAYOUTS_MARKER=721635

# Google Analytics (optional)
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# Site URL
NEXT_PUBLIC_SITE_URL=https://skyscout.ca
