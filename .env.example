# ──────────────────────────────────────────────────
# SkyScout — Environment Variables
# ──────────────────────────────────────────────────
# Copy to .env.local — NEVER commit .env.local to git

# Travelpayouts White Label ID (REQUIRED)
# Get from: Travelpayouts → Tools → White Label Web → Create/Edit
# The number in the WL settings URL
NEXT_PUBLIC_WL_ID=your_wl_id_here

# Your Travelpayouts marker (affiliate ID)
TRAVELPAYOUTS_MARKER=721635

# Your site URL (for WL host config)
NEXT_PUBLIC_SITE_URL=https://skyscout-two.vercel.app

# Google Analytics (optional)
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
